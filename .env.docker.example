# Copy this file to .env and update DATABASE_URL if your database endpoint changes.

# Current external HA PostgreSQL endpoint is exposed on the host at localhost:5000.
# From inside the backend Docker container, use host.docker.internal instead of localhost.
DATABASE_URL=postgresql+pg8000://postgres:postgres@host.docker.internal:5000/postgres

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000/api/v1

SECRET_KEY=change-me-for-local-docker
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
